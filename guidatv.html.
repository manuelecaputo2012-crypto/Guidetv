// TAB FILTERING
// ═══════════════════════════════════════════════════════
const TCAT={all:null,preferiti:'pin',sport:['sport'],film:['film'],serie:['serie'],
  news:['news'],intrattenimento:['intrattenimento'],documentario:['documentario']};
const TLABEL={all:'Tutti i canali',preferiti:'Preferiti',sport:'Sport',film:'Film',
  serie:'Serie TV',news:'News',intrattenimento:'Intrattenimento',documentario:'Documentari'};

function getTabChs(tab){
  if(tab==='all')return CHANNELS;
  if(tab==='preferiti'){
    return CHANNELS.filter(ch=>{
      const cur=ch.schedule[getCurIdx(ch.schedule)];
      return pinned.includes(pkey(ch.id,cur.title));
    });
  }
  const cats=TCAT[tab];if(!cats)return CHANNELS;
  return CHANNELS.filter(ch=>ch.cat&&ch.cat.some(c=>cats.includes(c)));
}

function switchTab(tab,el){
  currentTab=tab;
  document.querySelectorAll('.tab').forEach(b=>b.classList.remove('on'));
  el.classList.add('on');
  renderHome();
}

// ═══════════════════════════════════════════════════════
// HOME RENDER — single column
// ═══════════════════════════════════════════════════════
function renderHome(){
  const chs=getTabChs(currentTab);
  document.getElementById('homeLabel').textContent=TLABEL[currentTab]||'Canali';
  const list=document.getElementById('chList');
  list.innerHTML='';
  if(chs.length===0){
    list.innerHTML='<div style="padding:40px 20px;text-align:center;font-size:14px;color:var(--text3)">Nessun canale per questa categoria</div>';
    return;
  }
  chs.forEach(ch=>{
    const idx=getCurIdx(ch.schedule);
    const cur=ch.schedule[idx];
    const pct=getPct(ch.schedule,idx);
    const endT=getEndT(ch.schedule,idx);
    const row=document.createElement('div');
    row.className='ch-row';
    row.dataset.chId=ch.id;

    // Logo
    const logoDiv=document.createElement('div');
    logoDiv.className='ch-row-logo';
    const hue=((ch.num*67)%360);
    logoDiv.style.background=`hsl(${hue},50%,16%)`;
    const img=document.createElement('img');
    img.alt=ch.name;
    img.onerror=function(){
      this.remove();
      const fb=document.createElement('div');
      fb.className='ch-row-logo-fb';
      fb.textContent=ch.name.substring(0,3).toUpperCase();
      fb.style.cssText=`color:hsl(${hue},70%,65%);font-weight:700;font-size:10px`;
      logoDiv.appendChild(fb);
    };
    img.src=ch.logo;
    logoDiv.appendChild(img);

    // Body
    const body=document.createElement('div');
    body.className='ch-row-body';
    body.innerHTML=
      `<div class="ch-row-top"><span class="ch-row-name">${ch.name}</span><span class="ch-row-num">CH ${ch.num}</span></div>`+
      `<div class="ch-row-prog">${cur.title}</div>`;

    // Right
    const right=document.createElement('div');
    right.className='ch-row-right';
    right.innerHTML=
      `<div class="live-badge"><span class="live-badge-dot"></span>Live</div>`+
      `<div class="ch-row-bar-wrap"><div class="ch-row-bar"><div class="ch-row-bar-fill" style="width:${pct}%"></div></div></div>`+
      `<div class="ch-row-cat">${cur.cat}</div>`;

    row.appendChild(logoDiv);row.appendChild(body);row.appendChild(right);
    row.addEventListener('click',()=>openDetail(ch.id));
    list.appendChild(row);
  });
}

