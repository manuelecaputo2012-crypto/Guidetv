const SKINS_LIST = [
  {id:'tv',      emoji:'📺', label:'TV'},
  {id:'star',    emoji:'⭐', label:'Star'},
  {id:'fire',    emoji:'🔥', label:'Fire'},
  {id:'bolt',    emoji:'⚡', label:'Bolt'},
  {id:'moon',    emoji:'🌙', label:'Moon'},
  {id:'rocket',  emoji:'🚀', label:'Rocket'},
  {id:'diamond', emoji:'💎', label:'Diamond'},
  {id:'crown',   emoji:'👑', label:'Crown'},
  {id:'ghost',   emoji:'👻', label:'Ghost'},
  {id:'robot',   emoji:'🤖', label:'Robot'},
  {id:'alien',   emoji:'👽', label:'Alien'},
  {id:'ninja',   emoji:'🥷', label:'Ninja'},
  {id:'cat',     emoji:'🐱', label:'Gatto'},
  {id:'lion',    emoji:'🦁', label:'Leone'},
  {id:'wolf',    emoji:'🐺', label:'Lupo'},
  {id:'fox',     emoji:'🦊', label:'Volpe'},
  {id:'bear',    emoji:'🐻', label:'Orso'},
  {id:'dragon',  emoji:'🐲', label:'Drago'},
];

let chosenSkin = localStorage.getItem('gtv_skin') || 'tv';
let chosenSkinData = null; // per foto custom

function goToSkin(){
  // Nascondi splash
  const splash = document.getElementById('scr-splash');
  splash.classList.add('hidden');
  setTimeout(()=>{ splash.style.display='none'; }, 400);

  // Se skin già salvata → vai diretto all'app
  if(localStorage.getItem('gtv_skin_confirmed')){
    launchApp(); return;
  }

  // Mostra schermata skin
  buildSkinGrid();
  document.getElementById('scr-skin').classList.add('visible');

  // Handler foto
  document.getElementById('skinFileUpload').onchange = function(){
    const f = this.files[0]; if(!f) return;
    const r = new FileReader();
    r.onload = e => {
      chosenSkinData = e.target.result;
      chosenSkin = 'custom';
      // Aggiorna preview
      const big = document.getElementById('skinPreviewBig');
      big.innerHTML = `<img src="${chosenSkinData}" style="width:100%;height:100%;object-fit:cover">`;
      document.getElementById('skinPreviewLabel').textContent = 'Foto tua';
      // Deseleziona tutti
      document.querySelectorAll('.skin-card').forEach(c=>c.classList.remove('selected'));
    };
    r.readAsDataURL(f);
  };
}

function buildSkinGrid(){
  const grid = document.getElementById('skinGrid');
  grid.innerHTML = '';
  SKINS_LIST.forEach(sk => {
    const card = document.createElement('div');
    card.className = 'skin-card' + (chosenSkin===sk.id ? ' selected' : '');
    card.innerHTML = `
      <span class="skin-emoji">${sk.emoji}</span>
      <span class="skin-label">${sk.label}</span>
      <div class="skin-check">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
      </div>`;
    card.addEventListener('click', () => {
      chosenSkin = sk.id;
      chosenSkinData = null;
      // Aggiorna selezione visiva
      document.querySelectorAll('.skin-card').forEach(c=>c.classList.remove('selected'));
      card.classList.add('selected');
      // Aggiorna preview
      const big = document.getElementById('skinPreviewBig');
      big.innerHTML = '';
      big.textContent = sk.emoji;
      document.getElementById('skinPreviewLabel').textContent = sk.label;
    });
    grid.appendChild(card);
  });
}

function confirmSkinAndStart(){
  // Salva skin scelta
  if(chosenSkinData){
    localStorage.setItem('gtv_skin', 'custom');
    localStorage.setItem('gtv_skin_data', chosenSkinData);
    currentSkin = chosenSkinData;
  } else {
    const sk = SKINS_LIST.find(s=>s.id===chosenSkin);
    const emoji = sk ? sk.emoji : '📺';
    localStorage.setItem('gtv_skin', emoji);
    currentSkin = emoji;
  }
  localStorage.setItem('gtv_skin_confirmed', '1');
  // Nascondi skin screen
  const skinScr = document.getElementById('scr-skin');
  skinScr.classList.add('hidden');
  setTimeout(()=>{ skinScr.classList.remove('visible'); skinScr.classList.remove('hidden'); }, 400);
  launchApp();
}

function launchApp(){
  document.getElementById('scr-app').classList.add('active');
  goHome();
  tick();
}


