// REAL-TIME UPDATE
// ═══════════════════════════════════════════════════════
let lastSnap='';
function updateBars(){
  if(!activeChId){
    document.querySelectorAll('.ch-row').forEach(row=>{
      const ch=CHANNELS.find(c=>c.id===+row.dataset.chId);if(!ch)return;
      const idx=getCurIdx(ch.schedule);
      const fill=row.querySelector('.ch-row-bar-fill');
      if(fill)fill.style.width=getPct(ch.schedule,idx)+'%';
    });
  }else{
    const fill=document.querySelector('.prog-progress-fill');
    if(fill){const ch=CHANNELS.find(c=>c.id===activeChId);if(ch)fill.style.width=getPct(ch.schedule,getCurIdx(ch.schedule))+'%'}
  }
}
function checkProgChange(){
  const snap=CHANNELS.map(ch=>`${ch.id}:${getCurIdx(ch.schedule)}`).join('|');
  if(snap!==lastSnap){lastSnap=snap;
    if(activeChId){const ch=CHANNELS.find(c=>c.id===activeChId);if(ch)renderDetailPrograms(ch)}
    else renderHome();
  }
}
setInterval(updateBars,1000);
setInterval(checkProgChange,30000);

