const SKINS=[
  {id:'tv',e:'📺'},{id:'star',e:'⭐'},{id:'fire',e:'🔥'},{id:'bolt',e:'⚡'},
  {id:'moon',e:'🌙'},{id:'rocket',e:'🚀'},{id:'diamond',e:'💎'},{id:'crown',e:'👑'},
  {id:'ghost',e:'👻'},{id:'robot',e:'🤖'},{id:'alien',e:'👽'},{id:'ninja',e:'🥷'},
];
let currentSkin = localStorage.getItem('gtv_skin') || '📺';
if(currentSkin==='custom') currentSkin = localStorage.getItem('gtv_skin_data') || '📺';

function saveSkin(v){localStorage.setItem('gtv_skin',v);currentSkin=v}

function openProfile(){
  document.getElementById('pPinned').textContent=pinned.length;
  document.getElementById('pHidden').textContent=hidden.length;
  // Aggiorna avatar big
  const big=document.getElementById('profAvatarBig');
  if(currentSkin.startsWith('data:')){
    big.innerHTML=`<img src="${currentSkin}" style="width:100%;height:100%;object-fit:cover">`;
  } else {
    big.textContent=currentSkin;
  }
  // Costruisci griglia skin
  const grid=document.getElementById('skinGrid');
  grid.innerHTML='';
  SKINS.forEach(sk=>{
    const el=document.createElement('div');
    el.style.cssText='aspect-ratio:1;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:30px;cursor:pointer;border:2px solid var(--border);background:var(--bg3);transition:all .18s;-webkit-tap-highlight-color:transparent';
    el.textContent=sk.e;
    if(currentSkin===sk.e) el.style.borderColor='#ff3b30';
    el.addEventListener('click',()=>{
      saveSkin(sk.e);
      big.textContent=sk.e;
      grid.querySelectorAll('div').forEach(d=>d.style.borderColor='var(--border)');
      el.style.borderColor='#ff3b30';
      showToast('Avatar aggiornato!');
    });
    grid.appendChild(el);
  });
  // Carica foto
  document.getElementById('skinFileIn').onchange=function(){
    const f=this.files[0];if(!f)return;
    const r=new FileReader();
    r.onload=e=>{
      saveSkin(e.target.result);
      big.innerHTML=`<img src="${e.target.result}" style="width:100%;height:100%;object-fit:cover">`;
      showToast('Foto aggiornata!');
    };
    r.readAsDataURL(f);
  };
  document.getElementById('profilePanel').classList.add('open');
}

function closeProfile(){document.getElementById('profilePanel').classList.remove('open')}

function resetHidden(){
  hidden=[];saveHid();
  document.querySelectorAll('.prog-item.hidden').forEach(el=>el.classList.remove('hidden'));
  document.getElementById('pHidden').textContent=0;
  showToast('Programmi ripristinati!');
  closeProfile();
}

