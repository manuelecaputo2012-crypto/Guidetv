<!DOCTYPE html>

<html lang="it" data-theme="dark">
<head>
<meta name="referrer" content="no-referrer">
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black">
<title>GuidaTV</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
/* ───── TOKENS ───── */
[data-theme="dark"]{
  --bg:#080808;--bg2:#111;--bg3:#1a1a1a;--bg4:#242424;--bg5:#2e2e2e;
  --border:rgba(255,255,255,.07);--border2:rgba(255,255,255,.13);
  --text:#f0f0f0;--text2:#8a8a8a;--text3:#4a4a4a;
  --live:#ff3b30;--pin:#ffd60a;--accent:#ff3b30;
  --input-bg:#161616;--card:#111;
}
[data-theme="light"]{
  --bg:#f2f2f2;--bg2:#fff;--bg3:#e8e8e8;--bg4:#ddd;--bg5:#c8c8c8;
  --border:rgba(0,0,0,.08);--border2:rgba(0,0,0,.15);
  --text:#0a0a0a;--text2:#606060;--text3:#aaa;
  --live:#ff3b30;--pin:#b8860b;--accent:#ff3b30;
  --input-bg:#fff;--card:#fff;
}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;overflow:hidden;-webkit-text-size-adjust:100%}
body{
background:var(–bg);color:var(–text);
font-family:‘Inter’,sans-serif;font-size:15px;line-height:1.5;
-webkit-font-smoothing:antialiased;
overscroll-behavior:none;
}
::-webkit-scrollbar{width:3px;height:3px}
::-webkit-scrollbar-thumb{background:var(–bg5);border-radius:2px}

/* ───── SCREENS ───── */
.screen{
position:fixed;inset:0;
display:none;flex-direction:column;
background:var(–bg);
z-index:10;
}
.screen.active{display:flex}

/* ───── APP SHELL ───── */
#scr-app{background:var(–bg)}
.app-bar{
background:var(–bg);border-bottom:1px solid var(–border);
padding:0 14px;
/* safe area top */
padding-top:env(safe-area-inset-top,0px);
flex-shrink:0;
position:sticky;top:0;z-index:50;
}
.app-bar-row1{
height:50px;display:flex;align-items:center;gap:10px;
}
.app-bar-row2{padding-bottom:10px}

.hdr-back{
width:36px;height:36px;border-radius:10px;
border:1px solid var(–border2);background:none;
color:var(–text2);cursor:pointer;
display:none;align-items:center;justify-content:center;
flex-shrink:0;-webkit-tap-highlight-color:transparent;
transition:background .15s;
}
.hdr-back.on{display:flex}
.hdr-back:active{background:var(–bg3)}

.hdr-logo{
display:flex;align-items:center;gap:7px;
font-family:‘JetBrains Mono’,monospace;font-size:14px;font-weight:500;
letter-spacing:.07em;color:var(–text);flex-shrink:0;
}
.hdr-logo .ic{
width:24px;height:24px;background:#ff3b30;border-radius:6px;
display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
.hdr-spacer{flex:1}
.hdr-clock{
font-family:‘JetBrains Mono’,monospace;font-size:12px;
color:var(–text2);flex-shrink:0;
}
.hdr-theme{
width:36px;height:36px;border-radius:10px;
border:1px solid var(–border2);background:none;
color:var(–text2);cursor:pointer;
display:flex;align-items:center;justify-content:center;
flex-shrink:0;-webkit-tap-highlight-color:transparent;
}
.hdr-theme:active{background:var(–bg3)}
.hdr-profile{
width:36px;height:36px;border-radius:50%;
border:2px solid var(–border2);background:var(–bg3);
cursor:pointer;overflow:hidden;flex-shrink:0;
display:flex;align-items:center;justify-content:center;
font-size:15px;-webkit-tap-highlight-color:transparent;
}
.hdr-profile:active{border-color:#ff3b30}
.hdr-profile img{width:100%;height:100%;object-fit:cover}

/* SEARCH — full width */
.search-wrap{position:relative;width:100%}
.search-input{
width:100%;padding:12px 14px 12px 42px;
border-radius:13px;border:1.5px solid var(–border2);
background:var(–bg3);color:var(–text);
font-family:‘Inter’,sans-serif;font-size:16px;
outline:none;-webkit-appearance:none;
transition:border-color .18s,background .18s;
}
.search-input:focus{border-color:#ff3b30;background:var(–bg2)}
.search-input::placeholder{color:var(–text3)}
.search-ico{
position:absolute;left:13px;top:50%;transform:translateY(-50%);
color:var(–text3);pointer-events:none;
}

/* SEARCH DROPDOWN — fixed, full width, always readable */
.search-drop{
position:fixed;left:0;right:0;
background:var(–bg2);border-top:1px solid var(–border2);
border-bottom:1px solid var(–border2);
display:none;z-index:999;
max-height:50vh;overflow-y:auto;
-webkit-overflow-scrolling:touch;
box-shadow:0 8px 32px rgba(0,0,0,.6);
}
.search-drop.open{display:block}
.sr-item{
display:flex;align-items:center;gap:13px;
padding:13px 16px;border-bottom:1px solid var(–border);
cursor:pointer;-webkit-tap-highlight-color:transparent;
transition:background .12s;
}
.sr-item:last-child{border-bottom:none}
.sr-item:active{background:var(–bg3)}
.sr-logo{
width:40px;height:40px;border-radius:9px;
background:var(–bg4);overflow:hidden;flex-shrink:0;
display:flex;align-items:center;justify-content:center;
}
.sr-logo img{width:100%;height:100%;object-fit:contain;padding:4px}
.sr-info{flex:1;min-width:0}
.sr-prog{font-size:15px;font-weight:600;color:var(–text);
white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.sr-ch{font-size:12px;color:var(–text2);margin-top:1px}
.sr-dot{width:7px;height:7px;border-radius:50%;background:#ff3b30;flex-shrink:0}
.sr-empty{padding:20px 16px;font-size:14px;color:var(–text2);text-align:center}

/* TABS */
.tabs{
border-bottom:1px solid var(–border);background:var(–bg);
display:flex;overflow-x:auto;scrollbar-width:none;flex-shrink:0;
padding:0 14px;
}
.tabs::-webkit-scrollbar{display:none}
.tab{
flex-shrink:0;padding:12px 16px;
font-family:‘Inter’,sans-serif;font-size:13px;font-weight:500;
color:var(–text2);background:none;border:none;
border-bottom:2px solid transparent;cursor:pointer;
white-space:nowrap;transition:all .18s;
-webkit-tap-highlight-color:transparent;
}
.tab:active{color:var(–text)}
.tab.on{color:var(–text);border-bottom-color:var(–text)}

/* ───── VIEWS ───── */
.view{display:none;flex:1;overflow:hidden;flex-direction:column}
.view.on{display:flex}

/* HOME VIEW — single column channel list */
.home-scroll{
flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;
overscroll-behavior-y:contain;
}
.home-scroll::-webkit-scrollbar{display:none}

.home-header{
padding:14px 16px 10px;
display:flex;align-items:center;gap:7px;
}
.home-live-dot{
width:7px;height:7px;border-radius:50%;background:#ff3b30;
animation:blink 1.4s ease-in-out infinite;flex-shrink:0;
}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.25}}
.home-header-label{font-size:12px;font-weight:600;color:var(–text2);letter-spacing:.04em}

/* CHANNEL ROW */
.ch-row{
display:flex;align-items:center;gap:14px;
padding:14px 16px;
border-bottom:1px solid var(–border);
cursor:pointer;transition:background .13s;
-webkit-tap-highlight-color:transparent;
min-height:76px;
}
.ch-row:active{background:var(–bg2)}
.ch-row-logo{
width:48px;height:48px;border-radius:11px;
background:var(–bg3);overflow:hidden;flex-shrink:0;
display:flex;align-items:center;justify-content:center;
}
.ch-row-logo img{width:100%;height:100%;object-fit:contain;padding:5px}
.ch-row-logo-fb{font-family:‘JetBrains Mono’,monospace;font-size:9px;color:var(–text3);text-align:center;padding:4px}
.ch-row-body{flex:1;min-width:0}
.ch-row-top{display:flex;align-items:center;gap:6px;margin-bottom:3px}
.ch-row-name{font-size:15px;font-weight:600;color:var(–text);
white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.ch-row-num{font-family:‘JetBrains Mono’,monospace;font-size:10px;
color:var(–text3);flex-shrink:0}
.ch-row-prog{font-size:13px;color:var(–text2);
white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.ch-row-cat{font-size:11px;font-weight:600;letter-spacing:.07em;
color:var(–text3);text-transform:uppercase;flex-shrink:0}
.ch-row-right{flex-shrink:0;display:flex;flex-direction:column;align-items:flex-end;gap:4px}
.live-badge{
display:flex;align-items:center;gap:4px;
font-size:9px;font-weight:700;letter-spacing:.08em;
color:#ff3b30;
}
.live-badge-dot{width:5px;height:5px;border-radius:50%;background:#ff3b30;
animation:blink 1.4s ease-in-out infinite}
.ch-row-bar-wrap{width:48px}
.ch-row-bar{height:2px;background:var(–bg4);border-radius:1px;overflow:hidden}
.ch-row-bar-fill{height:100%;background:#ff3b30;border-radius:1px;transition:width 1s linear}

/* ───── DETAIL VIEW — full screen overlay ───── */
.detail-overlay{
position:fixed;inset:0;z-index:60;
background:var(–bg);
display:none;flex-direction:column;
transform:translateX(100%);
transition:transform .28s cubic-bezier(.4,0,.2,1);
}
.detail-overlay.open{
display:flex;
transform:translateX(0);
}

/* detail header */
.detail-bar{
background:var(–bg);border-bottom:1px solid var(–border);
padding:0 14px;
padding-top:env(safe-area-inset-top,0px);
flex-shrink:0;
display:flex;align-items:center;gap:12px;
height:calc(50px + env(safe-area-inset-top,0px));
}
.detail-ch-logo{
width:32px;height:32px;border-radius:7px;
background:var(–bg3);overflow:hidden;flex-shrink:0;
display:flex;align-items:center;justify-content:center;
}
.detail-ch-logo img{width:100%;height:100%;object-fit:contain;padding:3px}
.detail-ch-name{font-size:15px;font-weight:600;color:var(–text);
white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex:1}
.detail-scroll{
flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;
}
.detail-scroll::-webkit-scrollbar{display:none}

/* programs list in detail */
.prog-list-wrap{padding-bottom:32px}

.prog-item{
display:flex;gap:0;
border-bottom:1px solid var(–border);
position:relative;cursor:pointer;
-webkit-tap-highlight-color:transparent;
transition:background .13s;
}
.prog-item:active{background:var(–bg2)}
.prog-item.now{background:var(–bg2)}
.prog-item.now::before{
content:’’;position:absolute;left:0;top:0;bottom:0;
width:3px;background:#ff3b30;border-radius:0 2px 2px 0;
}
.prog-item.hidden{display:none}

.prog-item-left{
width:100px;flex-shrink:0;padding:16px 10px 14px 18px;
display:flex;flex-direction:column;gap:5px;
border-right:1px solid var(–border);
}
.prog-time{font-family:‘JetBrains Mono’,monospace;font-size:16px;font-weight:500;color:var(–text)}
.prog-now-badge{
display:flex;align-items:center;gap:4px;
font-size:9px;font-weight:700;letter-spacing:.08em;color:#ff3b30;
}
.prog-now-dot{width:5px;height:5px;border-radius:50%;background:#ff3b30;
animation:blink 1.4s ease-in-out infinite}
.prog-pin-tag{font-size:9px;font-weight:700;letter-spacing:.07em;color:var(–pin)}
.prog-cat-tag{font-size:10px;font-weight:600;letter-spacing:.08em;
color:var(–text3);text-transform:uppercase;margin-top:4px}

.prog-item-right{flex:1;padding:16px 16px 14px 14px;min-width:0}
.prog-title-row{font-size:15px;font-weight:600;color:var(–text);line-height:1.3;margin-bottom:5px}
.prog-desc-row{font-size:13px;color:var(–text2);line-height:1.55;margin-bottom:8px}
.prog-more{
font-size:12px;font-weight:500;color:var(–text3);
background:none;border:none;padding:0;
font-family:‘Inter’,sans-serif;cursor:pointer;
text-decoration:underline;text-decoration-color:var(–border2);
text-underline-offset:2px;
-webkit-tap-highlight-color:transparent;
}
.prog-progress{height:2px;background:var(–bg4);border-radius:1px;overflow:hidden;margin-top:10px}
.prog-progress-fill{height:100%;background:#ff3b30;border-radius:1px;transition:width 1s linear}

/* ───── PROGRAM MODAL (full info sheet) ───── */
.prog-modal-bg{
position:fixed;inset:0;z-index:80;
background:rgba(0,0,0,.85);
-webkit-backdrop-filter:blur(6px);backdrop-filter:blur(6px);
display:none;align-items:flex-end;
}
.prog-modal-bg.open{display:flex}
.prog-modal{
width:100%;background:var(–bg2);
border-radius:24px 24px 0 0;
max-height:94vh;display:flex;flex-direction:column;
animation:sheetUp .28s cubic-bezier(.4,0,.2,1);
}
@keyframes sheetUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
.pm-handle{width:40px;height:4px;border-radius:2px;background:var(–bg5);margin:12px auto 0;flex-shrink:0}
.pm-scroll{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding-bottom:env(safe-area-inset-bottom,20px)}
.pm-scroll::-webkit-scrollbar{display:none}
.pm-img{width:100%;aspect-ratio:16/9;background:var(–bg3);position:relative;overflow:hidden;flex-shrink:0}
.pm-img img{width:100%;height:100%;object-fit:cover;display:block}
.pm-img-grad{position:absolute;inset:0;background:linear-gradient(to bottom,transparent 50%,var(–bg2))}
.pm-img-fb{width:100%;height:100%;display:flex;align-items:center;justify-content:center}
.pm-body{padding:20px 20px 0}
.pm-badges{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:10px}
.pm-cat{font-size:11px;font-weight:700;letter-spacing:.1em;color:var(–text3);text-transform:uppercase}
.pm-live-tag{
display:flex;align-items:center;gap:4px;
font-size:10px;font-weight:700;letter-spacing:.08em;
color:#ff3b30;background:rgba(255,59,48,.12);
border:1px solid rgba(255,59,48,.25);padding:3px 9px;border-radius:20px;
}
.pm-pin-tag{
font-size:10px;font-weight:700;letter-spacing:.08em;
color:var(–pin);background:rgba(255,214,10,.1);
border:1px solid rgba(255,214,10,.25);padding:3px 9px;border-radius:20px;
}
.pm-title{font-size:24px;font-weight:700;color:var(–text);line-height:1.2;letter-spacing:-.02em;margin-bottom:8px}
.pm-ch-row{display:flex;align-items:center;gap:8px;margin-bottom:4px}
.pm-ch-logo{width:22px;height:22px;border-radius:5px;overflow:hidden;background:var(–bg4);display:flex;align-items:center;justify-content:center}
.pm-ch-logo img{width:100%;height:100%;object-fit:contain;padding:2px}
.pm-ch-name{font-size:13px;font-weight:600;color:var(–text2)}
.pm-time{font-family:‘JetBrains Mono’,monospace;font-size:13px;color:var(–text2);margin-bottom:16px}
.pm-progress{height:3px;background:var(–bg4);border-radius:2px;overflow:hidden;margin-bottom:18px}
.pm-progress-fill{height:100%;background:#ff3b30;border-radius:2px}
.pm-desc{font-size:17px;line-height:1.75;color:var(–text2);margin-bottom:24px;letter-spacing:-.01em}
.pm-actions{display:flex;flex-direction:column;gap:10px;padding:0 20px;margin-bottom:8px}
.pm-btn{
padding:16px;border-radius:14px;border:none;
font-family:‘Inter’,sans-serif;font-size:15px;font-weight:600;
cursor:pointer;display:flex;align-items:center;justify-content:center;gap:9px;
-webkit-tap-highlight-color:transparent;transition:opacity .14s;
}
.pm-btn:active{opacity:.7}
.pm-btn-pin{background:rgba(255,214,10,.12);color:var(–pin);border:1px solid rgba(255,214,10,.28)}
.pm-btn-pin.pinned{background:rgba(255,214,10,.22);border-color:var(–pin)}
.pm-btn-hide{background:rgba(255,59,48,.08);color:#ff3b30;border:1px solid rgba(255,59,48,.2)}
.pm-btn-close{background:var(–bg3);color:var(–text2);border:1px solid var(–border2);margin-bottom:4px}

/* ───── PROFILE PANEL ───── */
.profile-panel{
position:fixed;inset:0;z-index:70;
background:var(–bg);flex-direction:column;
transform:translateX(100%);transition:transform .28s cubic-bezier(.4,0,.2,1);
display:flex;
}
.profile-panel.open{transform:translateX(0)}
.prof-bar{
display:flex;align-items:center;gap:12px;
padding:60px 20px 20px;border-bottom:1px solid var(–border);
}
.prof-bar-title{font-size:18px;font-weight:700;color:var(–text);letter-spacing:-.01em}
.prof-scroll{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding:24px 20px 40px}
.prof-scroll::-webkit-scrollbar{display:none}
.prof-avatar-sec{
display:flex;flex-direction:column;align-items:center;gap:12px;
padding:28px;background:var(–bg3);border-radius:18px;margin-bottom:24px;
}
.prof-avatar-big{
width:90px;height:90px;border-radius:50%;
border:3px solid #ff3b30;background:var(–bg4);
overflow:hidden;display:flex;align-items:center;justify-content:center;
font-size:42px;
}
.prof-avatar-big img{width:100%;height:100%;object-fit:cover}
.prof-username{font-size:22px;font-weight:700;color:var(–text);letter-spacing:-.02em}
.prof-badge{
font-size:11px;font-weight:700;letter-spacing:.08em;color:#ff3b30;
background:rgba(255,59,48,.1);border:1px solid rgba(255,59,48,.25);
padding:4px 12px;border-radius:20px;text-transform:uppercase;
}
.prof-section{margin-bottom:20px}
.prof-section-title{font-size:10px;font-weight:700;letter-spacing:.1em;color:var(–text3);
text-transform:uppercase;margin-bottom:8px}
.prof-row{
display:flex;align-items:center;justify-content:space-between;
padding:14px 16px;background:var(–bg3);margin-bottom:1px;
}
.prof-row:first-of-type{border-radius:12px 12px 4px 4px}
.prof-row:last-of-type{border-radius:4px 4px 12px 12px;margin-bottom:0}
.prof-row-label{font-size:14px;color:var(–text2)}
.prof-row-value{font-size:14px;font-weight:600;color:var(–text)}
.btn-logout{
width:100%;padding:16px;border-radius:14px;
border:1px solid var(–border2);background:none;
color:#ff3b30;font-family:‘Inter’,sans-serif;
font-size:16px;font-weight:600;cursor:pointer;
display:flex;align-items:center;justify-content:center;gap:9px;
margin-top:8px;-webkit-tap-highlight-color:transparent;
}
.btn-logout:active{background:rgba(255,59,48,.08)}

/* TOAST */
.toast{
position:fixed;bottom:28px;left:50%;
transform:translateX(-50%) translateY(80px);
background:var(–text);color:var(–bg);
padding:11px 22px;border-radius:10px;
font-size:14px;font-weight:600;z-index:300;
transition:transform .3s cubic-bezier(.34,1.56,.64,1);
pointer-events:none;white-space:nowrap;
}
.toast.show{transform:translateX(-50%) translateY(0)}

/* ───── SPLASH ───── */
#scr-splash{
position:fixed;inset:0;z-index:100;
background:#080808;
display:flex;flex-direction:column;
align-items:center;justify-content:center;
gap:0;
transition:opacity .4s ease;
}
#scr-splash.hidden{opacity:0;pointer-events:none}
.splash-logo-wrap{
width:120px;height:120px;background:#ff3b30;
border-radius:30px;display:flex;align-items:center;justify-content:center;
box-shadow:0 0 60px rgba(255,59,48,.5);
animation:pulse-glow 2s ease-in-out infinite;
margin-bottom:32px;
}
@keyframes pulse-glow{
0%,100%{box-shadow:0 0 40px rgba(255,59,48,.4)}
50%{box-shadow:0 0 90px rgba(255,59,48,.65)}
}
.splash-name{
font-family:‘JetBrains Mono’,monospace;
font-size:36px;font-weight:500;
letter-spacing:.16em;
color:#f0f0f0;
text-align:center;
display:block;
width:100%;
margin-bottom:10px;
transform:none;
}
.splash-sub{
font-size:14px;color:#555;
text-align:center;
margin-bottom:48px;
display:block;
width:100%;
transform:none;
}
.splash-btn{
padding:18px 72px;border-radius:20px;border:none;
background:#ff3b30;color:#fff;
font-family:‘Inter’,sans-serif;font-size:18px;font-weight:700;
cursor:pointer;
box-shadow:0 8px 32px rgba(255,59,48,.4);
transition:transform .14s,box-shadow .14s;
-webkit-tap-highlight-color:transparent;
display:block;
}
.splash-btn:active{transform:scale(.96);}

/* ───── SKIN SCREEN ───── */
#scr-skin{
position:fixed;inset:0;z-index:99;
background:#080808;
display:none;flex-direction:column;
overflow-y:auto;-webkit-overflow-scrolling:touch;
padding:60px 20px 40px;
gap:24px;
transition:opacity .3s ease;
}
#scr-skin.visible{display:flex}
#scr-skin.hidden{opacity:0;pointer-events:none}
.skin-title{
font-size:26px;font-weight:700;color:#f0f0f0;
letter-spacing:-.02em;text-align:center;
}
.skin-sub{font-size:14px;color:#555;text-align:center;margin-top:-16px}
.skin-grid{
display:grid;grid-template-columns:repeat(3,1fr);
gap:14px;
}
.skin-card{
aspect-ratio:1;border-radius:20px;
background:#1a1a1a;border:2.5px solid #222;
display:flex;flex-direction:column;
align-items:center;justify-content:center;
gap:8px;cursor:pointer;
transition:all .2s;
-webkit-tap-highlight-color:transparent;
position:relative;
overflow:hidden;
}
.skin-card:active{transform:scale(.96)}
.skin-card.selected{border-color:#ff3b30;background:#1a0505}
.skin-card .skin-emoji{font-size:42px;line-height:1}
.skin-card .skin-label{font-size:11px;font-weight:600;color:#555;letter-spacing:.04em;text-transform:uppercase}
.skin-card.selected .skin-label{color:#ff3b30}
.skin-check{
position:absolute;top:8px;right:8px;
width:20px;height:20px;border-radius:50%;
background:#ff3b30;
display:none;align-items:center;justify-content:center;
}
.skin-card.selected .skin-check{display:flex}
.skin-upload-card{
border:2px dashed #333;background:none;
}
.skin-upload-card:active{border-color:#ff3b30}
.skin-photo-preview{
width:100%;height:100%;object-fit:cover;
border-radius:18px;position:absolute;inset:0;
}
.skin-confirm{
padding:18px;border-radius:16px;border:none;
background:#ff3b30;color:#fff;
font-family:‘Inter’,sans-serif;font-size:17px;font-weight:700;
cursor:pointer;box-shadow:0 6px 24px rgba(255,59,48,.35);
transition:transform .14s;
-webkit-tap-highlight-color:transparent;
margin-top:8px;
}
.skin-confirm:active{transform:scale(.97)}

@media(max-width:380px){
.prog-item-left{width:84px}
.pm-title{font-size:20px}
.pm-desc{font-size:15px}
}
</style>

