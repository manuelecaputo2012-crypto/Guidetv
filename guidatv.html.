  if(this.value.trim())doSearch(this.value.trim());
});
document.addEventListener('click',e=>{
  if(!e.target.closest('.search-wrap')&&!e.target.closest('.search-drop'))
    searchDrop.classList.remove('open');
});
document.addEventListener('touchstart',e=>{
  if(!e.target.closest('.search-wrap')&&!e.target.closest('.search-drop'))
    searchDrop.classList.remove('open');
},{passive:true});

function positionDrop(){
  const rect=searchIn.getBoundingClientRect();
  searchDrop.style.top=(rect.bottom)+'px';
}

function doSearch(q){
  positionDrop();
  if(!q){searchDrop.classList.remove('open');return}
  const ql=q.toLowerCase();
  const results=[];
  CHANNELS.forEach(ch=>{
    const ci=getCurIdx(ch.schedule);
    ch.schedule.forEach((p,i)=>{
      const hay=[p.title,p.cat,p.short||'',ch.name].join(' ').toLowerCase();
      if(hay.includes(ql))results.push({ch,p,isNow:i===ci});
    });
  });
  searchDrop.innerHTML='';
  if(!results.length){
    const e=document.createElement('div');e.className='sr-empty';e.textContent='Nessun risultato trovato';
    searchDrop.appendChild(e);searchDrop.classList.add('open');return;
  }
  results.slice(0,12).forEach(({ch,p,isNow})=>{
    const item=document.createElement('div');item.className='sr-item';
    const logoD=document.createElement('div');logoD.className='sr-logo';
    const img=document.createElement('img');img.alt=ch.name;
    img.style.cssText='width:100%;height:100%;object-fit:contain;padding:4px';
    img.onerror=function(){this.remove()};img.src=ch.logo;
    logoD.appendChild(img);
    const info=document.createElement('div');info.className='sr-info';
    info.innerHTML=`<div class="sr-prog">${p.title}</div><div class="sr-ch">${ch.name} · ${p.t} · ${p.cat}</div>`;
    item.appendChild(logoD);item.appendChild(info);
    if(isNow){const dot=document.createElement('div');dot.className='sr-dot';item.appendChild(dot)}
    item.addEventListener('click',()=>{
      searchDrop.classList.remove('open');searchIn.value='';searchIn.blur();
      openDetail(ch.id);
    });
    item.addEventListener('touchend',e=>{
      e.preventDefault();
      searchDrop.classList.remove('open');searchIn.value='';searchIn.blur();
      openDetail(ch.id);
    });
    searchDrop.appendChild(item);
  });
  searchDrop.classList.add('open');
}

