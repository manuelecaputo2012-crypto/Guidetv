// ═══════════════════════════════════════════════════════
// TIME HELPERS
// ═══════════════════════════════════════════════════════
function toMin(t){const[h,m]=t.split(':').map(Number);return h*60+(m||0)}
function nowMin(){const n=new Date();return n.getHours()*60+n.getMinutes()}
function nowSec(){const n=new Date();return n.getHours()*3600+n.getMinutes()*60+n.getSeconds()}
function getCurIdx(sch){const nm=nowMin();let i=0;for(let j=0;j<sch.length;j++)if(toMin(sch[j].t)<=nm)i=j;return i}
function getPct(sch,idx){
  const ns=nowSec(),sm=toMin(sch[idx].t);
  const ei=(idx+1)%sch.length;let em=toMin(sch[ei].t);
  if(em<=sm)em+=24*60;
  return Math.max(0,Math.min(100,(ns-sm*60)/((em-sm)*60)*100));
}
function getEndT(sch,idx){return sch[(idx+1)%sch.length].t}

// CLOCK
function tick(){document.getElementById('clock').textContent=new Date().toLocaleTimeString('it-IT',{hour:'2-digit',minute:'2-digit',second:'2-digit'})}
setInterval(tick,1000);tick();

