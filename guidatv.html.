  renderDetailPrograms(ch);
  document.getElementById('detailOverlay').classList.add('open');
  document.getElementById('hdrBack').classList.add('on');
}

function closeDetail(){
  document.getElementById('detailOverlay').classList.remove('open');
  document.getElementById('hdrBack').classList.remove('on');
  activeChId=null;
}

function goHome(){
  closeDetail();
  // Switch to home view
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('on'));
  document.getElementById('view-home').classList.add('on');
  renderHome();
}

function renderDetailPrograms(ch){
  const wrap=document.getElementById('progListWrap');
  wrap.innerHTML='';
  const curIdx=getCurIdx(ch.schedule);
  const pct=getPct(ch.schedule,curIdx);
  const ordered=ch.schedule.map((p,i)=>({
    ...p,
    isNow:((i-curIdx+ch.schedule.length)%ch.schedule.length)===0,
    sortKey:(i-curIdx+ch.schedule.length)%ch.schedule.length
  })).sort((a,b)=>a.sortKey-b.sortKey);

  ordered.forEach(prog=>{
    const key=pkey(ch.id,prog.title);
    const isHid=hidden.includes(key);
    const isPin=pinned.includes(key);

    const item=document.createElement('div');
    item.className='prog-item'+(prog.isNow?' now':'')+(isHid?' hidden':'')+(isPin?' pinned':'');
    item.dataset.key=key;

    // Left
    const left=document.createElement('div');
    left.className='prog-item-left';
    left.innerHTML=
      `<div class="prog-time">${prog.t}</div>`+
      (prog.isNow?`<div class="prog-now-badge"><span class="prog-now-dot"></span>In onda</div>`:'')+
      (isPin?`<div class="prog-pin-tag">Fissato</div>`:'')+
      `<div class="prog-cat-tag">${prog.cat}</div>`;

    // Right
    const right=document.createElement('div');
    right.className='prog-item-right';

    // Thumb
    const thumbWrap=document.createElement('div');
    const hue2=((ch.num*67)%360);
    thumbWrap.style.cssText=`width:100%;aspect-ratio:16/9;border-radius:8px;overflow:hidden;margin-bottom:10px;flex-shrink:0;position:relative;background:hsl(${hue2},40%,13%)`;
    if(prog.img){
      const tImg=document.createElement('img');
      
      tImg.style.cssText='position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block';
      tImg.onerror=function(){this.remove()};
      tImg.src=prog.img;
      thumbWrap.appendChild(tImg);
    }

    const titleEl=document.createElement('div');
    titleEl.className='prog-title-row';
    titleEl.textContent=prog.title;

    const descEl=document.createElement('div');
    descEl.className='prog-desc-row';
    descEl.textContent=prog.short||'';

    const moreBtn=document.createElement('button');
    moreBtn.className='prog-more';
    moreBtn.textContent='Mostra tutto';
    moreBtn.addEventListener('click',e=>{
      e.stopPropagation();
      openProgModal(ch.id,prog.title,prog.t);
    });

    if(prog.isNow){
      const progBar=document.createElement('div');
      progBar.className='prog-progress';
      const fill=document.createElement('div');
      fill.className='prog-progress-fill';
      fill.style.width=pct+'%';
      progBar.appendChild(fill);
      right.appendChild(thumbWrap);right.appendChild(titleEl);right.appendChild(descEl);right.appendChild(moreBtn);right.appendChild(progBar);
    }else{
      right.appendChild(thumbWrap);right.appendChild(titleEl);right.appendChild(descEl);right.appendChild(moreBtn);
    }

    item.appendChild(left);item.appendChild(right);

    // long press
    let lpt;
    item.addEventListener('mousedown',e=>{lpt=setTimeout(()=>{pmKey=key;pmChId=ch.id;openProgModal(ch.id,prog.title,prog.t)},600)});
    item.addEventListener('mouseup',()=>clearTimeout(lpt));
    item.addEventListener('mouseleave',()=>clearTimeout(lpt));
    item.addEventListener('touchstart',e=>{lpt=setTimeout(()=>{pmKey=key;pmChId=ch.id;openProgModal(ch.id,prog.title,prog.t)},600)},{passive:true});
    item.addEventListener('touchend',()=>clearTimeout(lpt));
    item.addEventListener('touchmove',()=>clearTimeout(lpt));

    wrap.appendChild(item);
  });
}

// ═══════════════════════════════════════════════════════
// PROGRAM MODAL
// ═══════════════════════════════════════════════════════
function openProgModal(chId,progTitle,progT){
  const ch=CHANNELS.find(c=>c.id===chId);if(!ch)return;
  const prog=ch.schedule.find(p=>p.title===progTitle&&p.t===progT);if(!prog)return;
  pmKey=pkey(chId,progTitle);pmChId=chId;

  const curIdx=getCurIdx(ch.schedule);
  const isNow=ch.schedule[curIdx].title===progTitle;
  const isPin=pinned.includes(pmKey);

  // Image - usa <img> con crossOrigin per evitare blocchi
  const imgWrap=document.getElementById('pmImg');
  const fb=document.getElementById('pmImgFb');
  // Rimuovi img precedente
  imgWrap.querySelectorAll('img.prog-img-real').forEach(el=>el.remove());
  imgWrap.style.backgroundImage='none';
  // Mostra fallback con logo canale
  fb.innerHTML='';
  const hueM=((ch.num*67)%360);
  imgWrap.style.background=`hsl(${hueM},45%,12%)`;
  fb.style.display='flex';
  if(prog.img){
    const pImg=document.createElement('img');
    pImg.className='prog-img-real';
    
    pImg.style.cssText='position:absolute;inset:0;width:100%;height:100%;object-fit:cover;border-radius:0;display:block;z-index:1';
    pImg.onload=function(){
      fb.style.display='none';
    };
    pImg.onerror=function(){fb.style.display='flex';this.remove()};
    pImg.src=prog.img;
    imgWrap.appendChild(pImg);
  }

  // Ch logo
  const chLogo=document.getElementById('pmChLogo');chLogo.innerHTML='';
  const cImg=document.createElement('img');
  cImg.alt=ch.name;cImg.style.cssText='width:100%;height:100%;object-fit:contain;padding:2px';
  cImg.onerror=function(){this.remove()};cImg.src=ch.logo;chLogo.appendChild(cImg);

  document.getElementById('pmCat').textContent=prog.cat;
  document.getElementById('pmTitle').textContent=prog.title;
  document.getElementById('pmChName').textContent=ch.name+' · CH '+ch.num;
  document.getElementById('pmTime').textContent=prog.t+(isNow?' — '+getEndT(ch.schedule,curIdx):'');
  document.getElementById('pmDesc').textContent=prog.full||prog.short||'';
  document.getElementById('pmLiveTag').style.display=isNow?'flex':'none';
  const pw=document.getElementById('pmProgressWrap');
  const pf=document.getElementById('pmProgressFill');
  if(isNow){pw.style.display='block';pf.style.width=getPct(ch.schedule,curIdx)+'%'}else{pw.style.display='none'}
  updatePmPin(isPin);
  document.getElementById('pmBg').classList.add('open');
  document.body.style.overflow='hidden';
}

function updatePmPin(isPin){
  const btn=document.getElementById('pmPinBtn');
  const tag=document.getElementById('pmPinTag');
  const lbl=document.getElementById('pmPinLabel');
  if(isPin){btn.classList.add('pinned');tag.style.display='inline-block';lbl.textContent='Rimuovi dai fissati'}
  else{btn.classList.remove('pinned');tag.style.display='none';lbl.textContent='Fissa programma'}
}
function closePm(){document.getElementById('pmBg').classList.remove('open');document.body.style.overflow='';pmKey=null;pmChId=null}
function handlePmBgClick(e){if(e.target===document.getElementById('pmBg'))closePm()}
function pmTogglePin(){
  if(!pmKey)return;
  const i=pinned.indexOf(pmKey);
  if(i>=0){pinned.splice(i,1);showToast('Rimosso dai fissati')}else{pinned.push(pmKey);showToast('Programma fissato')}
  savePin();updatePmPin(pinned.includes(pmKey));
  if(activeChId){const ch=CHANNELS.find(c=>c.id===activeChId);if(ch)renderDetailPrograms(ch)}
  else renderHome();
}
function pmHide(){
  if(!pmKey)return;
  if(!hidden.includes(pmKey)){hidden.push(pmKey);saveHid()}
  showToast('Programma nascosto');closePm();
  const card=document.querySelector(`.prog-item[data-key="${pmKey}"]`);
  if(card)card.classList.add('hidden');
}

